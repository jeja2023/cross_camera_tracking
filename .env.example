# .env 文件
# 此文件包含应用程序的所有环境变量配置。
# 在生产环境中，请确保妥善保管此文件，并避免在版本控制中直接提交敏感信息。
# 对于敏感信息，建议使用更安全的 Secret 管理方式。

# --- 项目元数据配置 ---
# PROJECT_NAME: 项目的名称。
# 用于应用程序的标识和显示。
PROJECT_NAME="Cross Camera Tracking"

# PROJECT_VERSION: 项目的版本号。
# 用于跟踪应用程序的版本。
PROJECT_VERSION="1.0.0"

# --- 目录名称配置 ---
# UPLOAD_DIR_NAME: 文件上传目录的名称。
UPLOAD_DIR_NAME="uploads"

# ENROLL_PERSON_IMAGES_DIR_NAME: 主动注册功能上传图片的目录名称。
ENROLL_PERSON_IMAGES_DIR_NAME="enroll_person_images"

# SAVED_STREAMS_DIR_NAME: 保存实时流的目录名称。
SAVED_STREAMS_DIR_NAME="saved_streams"

# DATABASE_CROPS_DIR_NAME: 数据库中裁剪图片存储目录的名称。
DATABASE_CROPS_DIR_NAME="crops"

# DATABASE_FULL_FRAMES_DIR_NAME: 数据库中完整视频帧截图存储目录的名称。
DATABASE_FULL_FRAMES_DIR_NAME="full_frames"

alembic_versionNAME="frontend/static"

# --- 模型文件配置 ---
# IMAGE_ANALYSIS_MODEL_NAME: 图片分析所使用的通用检测模型的名称。
IMAGE_ANALYSIS_MODEL_NAME="general_detection"

# ACTIVE_REID_MODEL_PATH: 主动 Re-ID 模型的文件路径。
# 如果不使用特定路径，通常设置为与 REID_MODEL_FILENAME 相同的文件名，或者设置为空字符串以禁用。
ACTIVE_REID_MODEL_PATH="osnet_ibn_x1_0.onnx"

# --- 数据库配置 ---
# DATABASE_URL: 数据库连接URL。
# 这是一个必需的配置项，用于指定应用程序连接到后端数据库（例如 MySQL）的详细信息。
# 格式示例: "mysql+pymysql://<用户名>:<密码>@<主机>:<端口>/<数据库名>"
# 例如: "mysql+pymysql://root:password@localhost:3306/my_database"
# 请根据您的实际数据库设置进行修改。
DATABASE_URL="mysql+pymysql://user:password@localhost:3306/your_database_name"

# --- Celery 异步任务队列配置 ---
# Celery 是一个分布式任务队列，用于处理耗时的操作（如视频解析）而不在主线程中阻塞应用程序。

# CELERY_BROKER_URL: Celery 消息代理的 URL。
# Celery Worker 从这里获取待执行的任务，并向其发送任务状态和结果。
# 支持的代理类型包括 Redis (推荐), RabbitMQ 等。
# 格式示例: "redis://localhost:6379/0" (Redis 默认配置)
CELERY_BROKER_URL="redis://your_redis_user:your_redis_password@localhost:6379/0"

# CELERY_RESULT_BACKEND: Celery 任务结果存储的 URL。
# Celery 将任务的最终结果（例如，成功、失败、返回值等）存储在这里，以便应用程序可以查询和获取这些结果。
# 格式示例: "redis://localhost:6379/0" (Redis 默认配置)
CELERY_RESULT_BACKEND="redis://your_redis_user:your_redis_password@localhost:6379/0"

# --- Redis 服务配置 (直接连接) ---
# REDIS_URL: Redis 服务器的连接 URL。
# 除了 Celery 以外，应用程序可能还会直接使用 Redis 进行数据存储、缓存、实时数据传输（如视频流帧）等。
# 格式示例: "redis://localhost:6379/0"
REDIS_URL="redis://your_redis_user:your_redis_password@localhost:6379/0"

# --- CORS 跨域资源共享配置 ---
# CORS (Cross-Origin Resource Sharing) 是一种安全机制，允许或限制Web应用程序的跨域请求，以防止恶意脚本。

# CORS_ORIGINS: 允许跨域请求的来源列表。
# 指定哪些前端域名（或IP地址）可以访问此后端API。可以使用逗号分隔多个来源。
# 特殊值 "*" 表示允许所有来源 (强烈不推荐在生产环境中使用，存在严重安全风险，应明确列出允许的域名)。
# 示例: "http://localhost:8080,https://yourfrontend.com"
CORS_ORIGINS="*"

# CORS_ALLOW_CREDENTIALS: 是否允许发送凭据 (cookies, HTTP 认证)。
# 如果设置为 "true"，则客户端在进行跨域请求时可以发送认证凭据（如 Cookie、HTTP 认证信息）。
# 这对于需要用户会话或认证的API是必需的。
CORS_ALLOW_CREDENTIALS="true"

# CORS_ALLOW_METHODS: 允许的 HTTP 方法列表。
# 指定哪些 HTTP 请求方法（如 GET, POST, PUT, DELETE, OPTIONS 等）允许跨域访问。
# 示例: "GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"

# CORS_ALLOW_HEADERS: 允许的 HTTP 请求头列表。
# 指定哪些 HTTP 请求头允许跨域访问。"*" 表示允许所有标准和非标准头。
# 示例: "Content-Type,Authorization,X-Requested-With"
CORS_ALLOW_HEADERS="*"

# --- JWT (JSON Web Token) 认证配置 ---
# JWT 用于用户认证和授权，确保只有经过身份验证的用户才能访问受保护的API端点。

# SECRET_KEY: 用于 JWT 签名的秘密密钥。
# 这是一个非常关键的安全参数。请务必更换为足够长、随机且复杂的字符串（至少32个字符）。
# 在生产环境中，此密钥绝不能泄露，并应定期更换。
SECRET_KEY="your_super_secret_jwt_key"

# ALGORITHM: JWT 签名算法。
# 指定用于对 JWT 进行签名和验证的加密算法。必须与生成令牌时使用的算法一致。
# 常用值如 "HS256" (HMAC with SHA-256) 或 "RS256" (RSA with SHA-256)。
ALGORITHM="HS256"

# ACCESS_TOKEN_EXPIRE_MINUTES: 访问令牌的过期时间 (分钟)。
# 用户成功登录后获取的访问令牌的有效时长。建议设置一个相对较短的时间（如 15-60 分钟）以提高安全性。
# 默认值: 30 分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=30

# REFRESH_TOKEN_EXPIRE_DAYS: 刷新令牌的过期时间 (天)。
# 刷新令牌用于在访问令牌过期后获取新的访问令牌，无需用户重新输入密码。
# 通常具有比访问令牌更长的有效期，但其泄露风险更高，应妥善保管。
# 默认值: 7 天。
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- 默认管理员用户配置 ---
# 这些配置项用于系统首次启动或数据库重置时创建默认管理员账户。
# 在生产环境中，出于安全考虑，请务必在部署后修改此默认管理员的密码。

# DEFAULT_ADMIN_USERNAME: 默认管理员用户的用户名。
# 此账户将拥有最高权限。
# 默认值: "admin"
DEFAULT_ADMIN_USERNAME="admin"

# DEFAULT_ADMIN_PASSWORD: 默认管理员用户的密码。
# 默认值: "Admin@123"
DEFAULT_ADMIN_PASSWORD="your_admin_password_here"

# --- 日志配置 ---
# 控制应用程序的日志输出行为，便于开发者调试、监控系统运行状况和追踪问题。

# LOG_LEVEL: 日志级别。
# 决定哪些严重程度的日志信息会被记录或显示。级别从低到高（信息量从多到少）为：
#   - DEBUG: 最详细的日志信息，通常只在开发和调试时启用。
#   - INFO: 一般性的信息消息，用于指示应用程序的正常运行流程。
#   - WARNING: 警告信息，表示可能出现问题，但应用程序仍能继续运行。
#   - ERROR: 错误信息，表示程序执行过程中发生的问题，可能导致部分功能失效。
#   - CRITICAL: 严重错误，表示非常严重的错误，可能导致应用程序停止运行。
LOG_LEVEL="WARNING"

# LOG_FILE_PATH: 日志文件路径。
# 如果设置了有效的路径（例如 "./logs/app.log"），日志将被写入指定文件。
# 如果此项为空，日志将默认输出到控制台 (stdout/stderr)。
LOG_FILE_PATH=""

# LOG_FILE_MAX_BYTES: 单个日志文件的最大大小 (字节)。
# 当日志文件达到此大小时，将进行自动轮换备份（即将当前日志文件重命名并创建新的空日志文件）。
# 例如，10485760 字节 = 10 MB。
LOG_FILE_MAX_BYTES=10485760

# LOG_FILE_BACKUP_COUNT: 日志文件备份数量。
# 指定保留多少个旧的日志文件备份。例如，设置为 5 将保留最新的 5 个轮换备份。
LOG_FILE_BACKUP_COUNT=5

# --- 模型文件存放配置 ---
# 这些配置定义了机器学习模型文件的存储位置和类型。

# MODELS_DIR_NAME: 模型文件存放的目录名称。
# 此目录是相对于后端应用程序的根目录（`backend/` 目录）的相对路径。
# 示例: 如果后端根目录是 `/app/backend`，且 `MODELS_DIR_NAME="models"`，则模型文件应位于 `/app/backend/models`。
MODELS_DIR_NAME="models"

# DEVICE_TYPE: 模型运行设备类型。
# 决定机器学习模型是在 CPU 上运行还是在 GPU 上运行，影响推理速度。
# 可选值:
#   - "CUDA": 优先使用NVIDIA GPU进行计算 (如果可用)。需要正确安装 NVIDIA 驱动、CUDA Toolkit 和兼容的深度学习框架（如 PyTorch/TensorFlow）。
#   - "CPU": 仅使用CPU进行计算。适用于没有NVIDIA GPU或希望在所有系统上兼容运行的场景。
DEVICE_TYPE="CPU"

# DETECTION_MODEL_FILENAME: 通用目标检测模型的文件名。
# 此模型用于检测图像或视频中各种对象（包括人）的位置和类别。
# 默认值: "yolov8n.onnx" (ONNX 格式的 YOLOv8 nano 模型，ONNX 是一种开放式的机器学习模型交换格式)
DETECTION_MODEL_FILENAME=yolov8n.onnx

# REID_MODEL_FILENAME: 人员重识别 (Re-ID) 模型的文件名。
# 此模型用于从人物图像中提取唯一的特征向量，以便在不同摄像头或时间点识别同一人物。
# 默认值: "osnet_ibn_x1_0.onnx" (ONNX 格式的 OSNet-IBN-X1-0 模型)
REID_MODEL_FILENAME=osnet_ibn_x1_0.onnx

# POSE_MODEL_FILENAME: 姿态估计模型的文件名。
# 此模型用于检测图像中人物的骨骼关键点（如关节位置），从而估计人物的姿态。
# 默认值: "yolov8n-pose.pt" (PyTorch 格式的 YOLOv8 nano pose 模型，`.pt` 是 PyTorch 模型的常见扩展名)
POSE_MODEL_FILENAME=yolov8n-pose.pt

# FACE_DETECTION_MODEL_FILENAME: 人脸检测模型的文件名。
# 此模型专门用于检测图像或视频帧中的人脸位置，输出人脸的边界框。
# 默认值: "yolov8n-face.onnx" (ONNX 格式的 YOLOv8 nano face 模型)
FACE_DETECTION_MODEL_FILENAME=yolov8n-face.onnx

# FACE_RECOGNITION_MODEL_FILENAME: 人脸识别模型的文件名。
# 此模型用于从检测到的人脸区域中提取高维生物特征向量，这些向量可用于人脸比对和身份识别。
# 默认值: "arcface.onnx" (ONNX 格式的 ArcFace 模型，常用于人脸识别)
FACE_RECOGNITION_MODEL_FILENAME=arcface.onnx

# GAIT_RECOGNITION_MODEL_FILENAME: 步态识别模型的文件名。
# 此模型用于从人物的步态序列（即连续多帧图像中人物行走的动态姿态）中提取特征，用于步态识别。
# 如果此项为空，则表示禁用步态识别功能。
GAIT_RECOGNITION_MODEL_FILENAME=

# CLOTHING_ATTRIBUTE_MODEL_FILENAME: 衣着属性识别模型的文件名。
# 此模型用于识别人物的衣着属性，例如上衣的颜色、款式，下装的类型、材质等。
# 如果此项为空，则表示禁用衣着属性识别功能。
CLOTHING_ATTRIBUTE_MODEL_FILENAME=

# REID_TRAIN_BATCH_SIZE: Re-ID 模型训练的批量大小。
# 在模型再训练时，每次模型更新参数所使用的样本数量。合理的批量大小可以提高训练效率和模型性能。
# 默认值: 32。
REID_TRAIN_BATCH_SIZE=32

# REID_TRAIN_LEARNING_RATE: Re-ID 模型训练的学习率。
# 学习率控制模型在每次迭代中更新参数的步长。合适的学习率对模型收敛至关重要。
# 默认值: 0.001。
REID_TRAIN_LEARNING_RATE=0.001

# --- 模型输入/输出特征维度配置 ---
# REID_INPUT_WIDTH: Re-ID 模型期望的输入图像宽度 (像素)。
# 在将人物裁剪图输入 Re-ID 模型之前，图像会被缩放到此宽度。
REID_INPUT_WIDTH=128

# REID_INPUT_HEIGHT: Re-ID 模型期望的输入图像高度 (像素)。
# 在将人物裁剪图输入 Re-ID 模型之前，图像会被缩放到此高度。
REID_INPUT_HEIGHT=256

# FEATURE_DIM: Re-ID 特征向量的维度。
# 指的是 Re-ID 模型输出的特征向量的长度。此维度是用于表示人物身份的关键信息。
# 例如，512 维意味着每个 Re-ID 特征是一个包含 512 个浮点数的向量。
FEATURE_DIM=512

# FACE_FEATURE_DIM: 人脸特征向量的维度。
# 指的是人脸识别模型输出的特征向量的长度。用于表示人脸的独特特征。
# 例如，512 维。
FACE_FEATURE_DIM=512

# GAIT_FEATURE_DIM: 步态特征向量的维度。
# 指的是步态识别模型输出的特征向量的长度。用于表示人物步态的独特性。
# 通常为了多模态融合方便，会尝试与 Re-ID 维度保持一致，例如 512 维。
GAIT_FEATURE_DIM=512

# --- 多模态融合权重配置 ---
# 当系统结合 Re-ID、人脸和步态等多种模态的特征进行匹配和相似度计算时，这些权重决定了每种特征的重要性。
# 确保所有启用的模态权重之和通常为 1.0 (如果所有模态都启用且参与融合，则其权重总和为 1)。

# REID_WEIGHT: Re-ID 特征在多模态融合中的权重 (0.0 到 1.0)。
# 较高的值表示 Re-ID 特征在最终匹配决策中扮演更重要的角色。
REID_WEIGHT=0.7

# FACE_WEIGHT: 人脸特征在多模态融合中的权重 (0.0 到 1.0)。
# 较高的值表示人脸特征在最终匹配决策中更重要。
FACE_WEIGHT=0.3

# GAIT_WEIGHT: 步态特征在多模态融合中的权重 (0.0 到 1.0)。
# 较高的值表示步态特征在最终匹配决策中更重要。
# 初始为 0.0 表示步态识别功能通常是禁用的或其特征不参与融合。
GAIT_WEIGHT=0.0

# --- Re-Ranking 算法参数 ---
# Re-Ranking 是一种后处理技术，用于改善初始相似度搜索结果的准确性，常用于人员重识别（Re-ID）任务。
# 它通过考虑候选结果之间的相互关系来优化排名。

# K1: Re-Ranking 算法参数 K1。
# 用于 k-reciprocal 近邻搜索的第一步，定义查找共同邻居的初始范围。
# 通常是较小的整数，例如 20。
K1=20

# K2: Re-Ranking 算法参数 K2。
# 另一个用于 k-reciprocal 近邻搜索的参数，通常小于或等于 K1。
K2=6

# LAMBDA_VALUE: Re-Ranking 算法参数 Lambda。
# 用于调整 Jaccard 距离和原始特征距离在最终相似度计算中的权重。
# 值为 0 意味着只考虑原始距离，值为 1 意味着只考虑 Jaccard 距离。
LAMBDA_VALUE=0.3

# --- 步态序列长度配置 ---
# GAIT_SEQUENCE_LENGTH: 步态特征提取所需的帧序列长度。
# 步态识别模型通常需要连续的多帧图像（即一个或多个完整的步态周期）来提取稳定和鲁棒的步态特征。
# 例如，如果设置为 30，表示需要收集 30 帧连续的人物剪影来形成一个步态序列并进行特征提取。
GAIT_SEQUENCE_LENGTH=30

# --- Faiss 索引配置 ---
# Faiss (Facebook AI Similarity Search) 是一个用于高效相似度搜索和聚类的库，尤其适用于大规模向量数据。

# FAISS_INDEX_PATH: Faiss 索引文件的路径。
# 用于存储构建好的 Faiss 索引（包含所有人物的特征向量），以便在应用程序启动时快速加载并进行特征向量搜索，避免每次从数据库重建。
FAISS_INDEX_PATH="faiss_index.bin"

# FAISS_ID_MAP_PATH: Faiss ID 映射文件的路径。
# 通常用于存储 Faiss 索引内部的向量 ID 与实际人物 UUID 之间的映射关系，方便根据搜索结果查询人物详情。
FAISS_ID_MAP_PATH="faiss_id_map.json"

# FAISS_DIMS: Faiss 索引的特征维度。
# 必须与存储在 Faiss 中的特征向量的维度一致（例如，与 `FEATURE_DIM` 相同）。
# 如果维度不匹配，Faiss 索引将无法正确工作。
FAISS_DIMS=512

# FAISS_METRIC: Faiss 索引的距离度量方法。
# 定义 Faiss 在进行相似度搜索时，如何计算特征向量之间的“距离”或“相似度”。
# 可选值:
#   - "L2": L2 距离 (欧氏距离的平方)。最常用的度量，适用于特征向量的绝对值差异有意义的场景。
#   - "COSINE": 余弦相似度。衡量向量方向的相似性，对向量的长度不敏感，常用于文本、图像等高维稀疏数据的相似度计算。
FAISS_METRIC="COSINE"

# FAISS_SEARCH_K: Faiss 搜索时返回的最近邻数量。
# 在执行 Faiss 相似度搜索（k-NN 搜索）时，此参数指定返回与查询向量最相似的 K 个结果。
# 较高的 K 值可能找到更多相关结果，但会增加计算量。
FAISS_SEARCH_K=20

# --- 人机回环审核配置 ---
# HUMAN_REVIEW_CONFIDENCE_THRESHOLD: 人机回环审核时，特征置信度阈值。
# 如果系统自动识别的人物特征（例如 Re-ID 特征）的置信度低于此阈值，该人物将被标记为需要人工审核或后续再训练。
# 阈值范围通常在 0.0 到 1.0 之间。
#   - 0.0: 所有结果都可能需要人工审核。
#   - 1.0: 只审核那些置信度极低（几乎为 0）的结果。
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.5

# --- 图片分析配置 ---
# IMAGE_ANALYSIS_MIN_PERSON_CONFIDENCE: 图片分析中人物检测的最低置信度阈值。
# 在对静态图片进行人物检测时，只有检测模型输出的置信度高于此阈值的人物才会被进一步处理和存储（如提取特征）。
# 低于此阈值的检测结果将被过滤掉。
IMAGE_ANALYSIS_MIN_PERSON_CONFIDENCE=0.5

# --- 主动注册配置 ---
# ENROLLMENT_MIN_PERSON_CONFIDENCE: 主动注册中人物检测的最低置信度阈值。
# 在用户主动上传图片进行人物注册时，此阈值决定了图片中检测到的人物是否会被接受并用于特征提取和入库。
# 低于此阈值的检测结果将被忽略。
ENROLLMENT_MIN_PERSON_CONFIDENCE=0.4

# FACE_DETECTION_CONFIDENCE_THRESHOLD: 人脸检测的最低置信度阈值。
# 在对人物区域进行人脸检测时，只有检测模型输出的置信度高于此阈值的人脸才会被认为是有效人脸并进行特征提取。
# 低于此阈值的检测结果将被过滤掉。
FACE_DETECTION_CONFIDENCE_THRESHOLD=0.5

# MIN_FACE_WIDTH: 人脸裁剪图的最小宽度 (像素)。
# 如果人脸检测模型输出的边界框宽度小于此值，即使置信度高，该人脸也会被忽略。
# 建议设置一个合理的值，例如 40-60 像素，以确保裁剪出的人脸有足够的可辨识度。
MIN_FACE_WIDTH=40

# MIN_FACE_HEIGHT: 人脸裁剪图的最小高度 (像素)。
# 如果人脸检测模型输出的边界框高度小于此值，即使置信度高，该人脸也会被忽略。
# 建议设置一个合理的值，例如 40-60 像素。
MIN_FACE_HEIGHT=40

# --- Tracker 和检测相关配置 ---
# TRACKER_PROXIMITY_THRESH: Tracker 中用于判断跟踪框邻近度的阈值。
# 用于衡量不同帧之间检测框的空间距离（如 IoU），以决定它们是否可能属于同一目标。
# 较高的值表示需要更严格的空间重叠才认为是同一目标。
TRACKER_PROXIMITY_THRESH=0.5

# TRACKER_APPEARANCE_THRESH: Tracker 中用于判断跟踪框外观相似度的阈值。
# 用于衡量不同帧之间检测框内人物外观特征（通常是 Re-ID 特征）的相似度。
# 较高的值表示需要更强的外观相似性才认为是同一目标。
TRACKER_APPEARANCE_THRESH=0.25

# TRACKER_HIGH_THRESH: Tracker 高置信度阈值。
# 在跟踪算法中，用于区分高置信度检测和低置信度检测的阈值。
# 高于此阈值的检测结果被认为是可靠的。
TRACKER_HIGH_THRESH=0.1

# TRACKER_LOW_THRESH: Tracker 低置信度阈值。
# 在跟踪算法中，用于处理低置信度检测的阈值，可能用于辅助匹配或短期跟踪。
# 低于此阈值的检测可能被认为是噪声或虚警。
TRACKER_LOW_THRESH=0.1

# TRACKER_NEW_TRACK_THRESH: Tracker 新轨迹初始化阈值。
# 当一个目标被连续检测到但没有匹配到现有轨迹时，其检测置信度需要高于此阈值才能创建新的跟踪轨迹。
# 较高的值会减少虚假轨迹的生成。
TRACKER_NEW_TRACK_THRESH=0.1

# TRACKER_MIN_HITS: 轨迹初始化所需的最低检测次数。
# 一个潜在的目标需要在连续的帧中被检测到至少 `TRACKER_MIN_HITS` 次，才会被确认为一个新的跟踪轨迹。
# 这有助于过滤掉单帧的虚警检测。
TRACKER_MIN_HITS=1

# TRACKER_TRACK_BUFFER: Tracker 轨迹保留帧数。
# 如果一个跟踪轨迹在连续 `TRACKER_TRACK_BUFFER` 帧内没有被检测到（即丢失），它将被视为终止。
# 较大的缓冲区可以处理短时间的遮挡，但会增加内存和计算开销。
TRACKER_TRACK_BUFFER=30

# VIDEO_PROCESSING_FRAME_RATE: 视频处理时，每秒处理的帧数。
# 在对离线视频文件进行分析时，指定每秒处理的帧数。较低的帧率可以减少计算量，但可能错过一些细节。
# 较高的帧率提供更精细的分析，但消耗更多资源。
VIDEO_PROCESSING_FRAME_RATE=25

# STREAM_PROCESSING_FRAME_RATE: 直播流处理时，每秒处理的帧数。
# 在处理实时视频流时，指定每秒处理的帧数。通常与视频源的实际帧率匹配或低于它，以控制处理负载。
STREAM_PROCESSING_FRAME_RATE=25

# VIDEO_COMMIT_BATCH_SIZE: 视频处理时，每次向数据库提交结果的批次大小。
# 批量提交可以减少数据库I/O操作的频率，从而提高处理效率，尤其是在处理大量检测结果时。
VIDEO_COMMIT_BATCH_SIZE=100

# DETECTION_CONFIDENCE_THRESHOLD: 目标检测的全局置信度阈值。
# 任何目标检测模型输出的结果（无论是人、车辆、其他物体等）的置信度低于此阈值都将被过滤。
# 这是对所有检测结果的通用过滤条件。
DETECTION_CONFIDENCE_THRESHOLD=0.5

# PERSON_CLASS_ID: 在目标检测模型中，代表“人物”类别的 ID。
# YOLO 等目标检测模型会将检测到的对象分类，此ID指定了模型内部“人”的类别索引。
# 通常在预训练的 YOLOv8 模型中，类别 ID 0 代表“person”。
PERSON_CLASS_ID=0

# --- Excel 导出相关配置 ---
# EXCEL_EXPORT_MAX_IMAGES: Excel 导出时，每个人的最大导出图片数量。
# 在导出人物信息到Excel文件时，限制每个被识别人物关联的裁剪图片数量，以避免生成过大的Excel文件。
EXCEL_EXPORT_MAX_IMAGES=30

# EXCEL_EXPORT_IMAGE_SIZE_PX: Excel 导出时，嵌入图片的大小 (像素)。
# 控制导出Excel文件中人物裁剪图缩略图的显示尺寸。
EXCEL_EXPORT_IMAGE_SIZE_PX=100

# EXCEL_EXPORT_ROW_HEIGHT_PT: Excel 导出时，包含图片的行的高度 (磅)。
# 配合 `EXCEL_EXPORT_IMAGE_SIZE_PX` 调整Excel中包含人物图片的行的高度，以确保图片完整且美观地显示。
EXCEL_EXPORT_ROW_HEIGHT_PT=75

# --- MJPEG 视频流帧率配置 ---
# MJPEG_STREAM_FPS: MJPEG 视频流每秒发送的帧数。
# 控制通过 HTTP MJPEG 流传输实时视频帧到前端的速度，影响前端实时预览的流畅度。
# 较高的帧率会使预览更流畅，但会增加网络带宽和服务器负载。
MJPEG_STREAM_FPS=20

# --- 文件上传和视频进度流配置 ---
# UPLOAD_CHUNK_SIZE_BYTES: 文件上传时，每次读取和写入的块大小 (字节)。
# 较大的块大小可以提高大文件（如视频文件）上传的效率，但可能在服务器端消耗更多内存。
UPLOAD_CHUNK_SIZE_BYTES=1048576

# VIDEO_PROGRESS_POLLING_INTERVAL_SECONDS: 视频处理进度轮询的间隔时间 (秒)。
# 前端客户端每隔此时间向后端轮询一次，以获取视频处理的最新进度和状态。
# 较短的间隔提供更实时的更新，但会增加后端请求负载。
VIDEO_PROGRESS_POLLING_INTERVAL_SECONDS=1 